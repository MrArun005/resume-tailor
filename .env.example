# Configure at least one provider. Claude is used by default when both are set.
# Copy this file to .env.local and fill in your key(s).
#
# PRIVACY NOTE: uploaded résumés are sent to whichever provider you configure.
# - Anthropic API: does NOT train on data sent via the API (good for private data).
# - Google Gemini: the FREE AI Studio tier MAY use your prompts to improve Google's
#   products. For private résumé data use a PAID Gemini API / Vertex AI tier, which
#   does not train on your content. Review each provider's current data policy.
#
# DEBUG_AI=1 enables verbose model-response logging to the terminal AND writes the
# full response (which contains résumé content) to gemini-last-response.txt. Leave
# it UNSET in any real/shared/deployed environment.

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
